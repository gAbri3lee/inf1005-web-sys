{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Azure Horizon (public)",
            "type": "php",
            "request": "launch",
            "runtimeArgs": [
                "-S",
                "localhost:8000",
                "-t",
                "public"
            ],
            "cwd": "${workspaceFolder}",
            "port": 0,
            "serverReadyAction": {
                "pattern": "Development Server \(http://localhost:8000\) started",
                "uriFormat": "http://localhost:8000/index.php",
                "action": "openExternally"
            }
        }
    ]
}
